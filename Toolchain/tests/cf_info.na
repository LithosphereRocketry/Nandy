# CompactFlash LBA mode parameters
@define CF_BASE 8
@define CF_DATA CF_BASE | 0
@define CF_ERROR_FEATURE CF_BASE | 1
@define CF_SECTOR_COUNT CF_BASE | 2
@define CF_LBA_7_0 CF_BASE | 3
@define CF_LBA_15_8 CF_BASE | 4
@define CF_LBA_23_16 CF_BASE | 5
@define CF_LBA_27_24_MODE CF_BASE | 6
@define CF_STATUS_CMD CF_BASE | 7

main:
    rdi 0
    wr sp
    jr cf_init
    jc cf_no_card
    rdq sector_buf
    jr cf_identify_drive
    rdq sector_buf
    jr dump_sector
    brk

cf_no_card:
    rdq nocardstr
    jr puts
    brk

# Based on 8-bit CF interface from waveguide.se
# https://www.waveguide.se/?article=8-bit-compact-flash-interface

# Initializes compactflash card in 8 bit mode
# Sets carry if no card was detected
cf_init:
    isp -4
    st sp 3
    rd y
    st sp 2
    rd ph
    st sp 1
    rd pl
    st sp 0

    rdi CF_ERROR_FEATURE
    wr y
    rd io
    # these bits of the error/feature register are defined as 0, so if any read
    # as 1, the bus is disconnected and being pulled high
    andi 0b00101010
    nzero
    jc cf_init_end
    
    # waveguide.se does a drive reset here with 0x04 but that's not actually
    # listed as a valid CF command
    jr cf_wait
    # Enable LBA mode
    rdi CF_LBA_27_24_MODE
    wr y
    rdi 0xE0
    wr io
    # Enable 8-bit access
    rdi CF_ERROR_FEATURE
    wr y
    rdi 0x01
    wr io
    rdi 0xEF
    jr cf_cmd 

    cclr
cf_init_end:
    ld sp 0
    wr pl
    ld sp 1
    wr ph
    ld sp 2
    wr y
    ld sp 3
    isp 4
    jp


# Read the CF info into the sector buffer
# Sector buffer address passed in q, clobbered
cf_identify_drive:
    isp -4
    st sp 3
    rd y
    st sp 2
    rd ph
    st sp 1
    rd pl
    st sp 0

    jr cf_wait
    rdi 0xEC
    jr cf_cmd
    jr cf_receive_sector

    ld sp 0
    wr pl
    ld sp 1
    wr ph
    ld sp 2
    wr y
    ld sp 3
    isp 4
    jp

# Wait for CF card to become un-busy
# clobbers Y, ACC contains status register
cf_wait:
    sw y
    rdi CF_STATUS_CMD
    sw y
cf_wait_loop:
    rd io
    sgn
    jc cf_wait_loop
    jp

# Send a command to the CF card
# Takes input in ACC, clobbers Y
cf_cmd:
    sw y
    rdi CF_STATUS_CMD
    sw y
    wr io
    jp

# Read sector into buffer after it is already prompted
# Sector buffer address passed in q, clobbered
cf_receive_sector:
    isp -4
    st sp 3
    rd y
    st sp 2
    rd ph
    st sp 1
    rd pl
    st sp 0

    jr cf_wait
    # wait for it to set DRDY
    rdi CF_STATUS_CMD
    wr y
    # move q into p in a ruthless, clobber-y way
    rd qh
    wr ph
    rd ql
    wr pl

    # ql will be our loop counter
    # qh is free for a potential "read sectors" command down the line, maybe
    # using acc as parameter?
    rdi 0
    wr ql
    rdi CF_DATA
    wr y

cf_receive_sector_loop:
    rd io
    st p+ 1
    rd io
    st p+ 1
    rd ql
    subi 1
    wr ql
    nzero
    jc cf_receive_sector_loop

cf_receive_sector_done:
    ld sp 0
    wr pl
    ld sp 1
    wr ph
    ld sp 2
    wr y
    ld sp 3
    isp 4
    jp

# Prints a 512 byte memory region (must be 2 byte aligned)
# Sector buffer address passed in q, clobbered
# clobbers acc, x, y
dump_sector:
    isp -3
    rd pl
    st sp 0
    rd ph
    st sp 1
    rdi 0
dump_sector_loop:
    st sp 2
    # unroll by two because we get a nice 256-cycle loop

    # load byte into acc
    swap ph qh
    swap pl ql
    ld p+ 1
    swap ph qh
    swap pl ql
    jr dump_byte

    rdi 0
    wr y
    rdi ' '
    wr io

    swap ph qh
    swap pl ql
    ld p+ 1
    swap ph qh
    swap pl ql
    jr dump_byte

    rdi 0
    wr y
    rdi ' '
    wr io

    ld sp 2
    subi 1
    andi 0x7
    nzero
    jc dump_sector_no_nl
    rdi '\r'
    wr io
    rdi '\n'
    wr io

dump_sector_no_nl:
    ld sp 2
    subi 1
    nzero
    jc dump_sector_loop

    ld sp 0
    wr pl
    ld sp 1
    wr ph
    isp 3
    jp


# input in acc, clobbers x, expects y already set
dump_byte:
    wr x
    sr
    sr
    sr
    sr
    subi 10
    nsgn
    jc dump_byte_letter
    addi '0' + 10
    wr io
    j dump_byte_chr2
dump_byte_letter:
    addi 'a'
    wr io

dump_byte_chr2:
    rd x
    andi 0xF

    subi 10
    nsgn
    jc dump_byte_letter2
    addi '0' + 10
    wr io
    j dump_byte_done
dump_byte_letter2:
    addi 'a'
    wr io

dump_byte_done:
    jp


# argument in q
# clobbers q
puts:
    isp -2
    st sp 0
    rd y
    st sp 1
    swap ph qh
    swap pl ql
    rdi 0
    wr y
    j puts_entry

puts_loop:
    wr io
puts_entry:
    ld p+ 1
    nzero
    jc puts_loop

puts_done:
    swap ph qh
    swap pl ql
    ld sp 1
    wr y
    ld sp 0
    jp


nocardstr:
@string "No CF card detected!\n"
failstr:
@string "CF card returned error!\n"

@static sector_buf 512

