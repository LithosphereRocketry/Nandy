# Twiddles harmless LBA address registers to make sure we can talk to the card

    rdi 8|4
    wr y
    rdi 123
    wr io
    rdi 8|5
    wr y
    rdi 234
    wr io

    rdi 8|4
    wr y
    rd io
    xori 123
    nzero
    jc fail
    rdi 8|5
    wr y
    rd io
    xori 234
    nzero
    jc fail
    rdq str_success
    jr puts
    brk

fail:
    rdq str_fail
    jr puts
    brk


# argument in q
# clobbers q
puts:
    isp -2
    st sp 0
    rd y
    st sp 1
    swap ph qh
    swap pl ql
    rdi 0
    wr y
    j puts_entry

puts_loop:
    wr io
puts_entry:
    ld p+ 1
    nzero
    jc puts_loop

puts_done:
    swap ph qh
    swap pl ql
    ld sp 1
    wr y
    ld sp 0
    jp

str_success:
@string "Register write/read successful!\n"
str_fail:
@string "Register write/read failed!\n"